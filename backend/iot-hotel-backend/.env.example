# 服务器配置
APP_HOST=localhost
APP_PORT=3000
NODE_ENV=development
API_PREFIX=/api/v1

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=iot_hotel_system

# Redis配置
REDIS_URL=redis://localhost:6379

# MQTT配置
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# AI服务配置（可选）
# AI_API_KEY=your_glm_api_key
# AI_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
