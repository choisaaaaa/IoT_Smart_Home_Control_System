  "description": "智慧酒店物联网控制系统 - 后端服务",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node --files src/server.ts",
    "build": "tsc --build",
    "start": "node dist/server.js",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
